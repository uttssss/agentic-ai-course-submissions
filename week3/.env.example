# Copy to .env and fill in. Loaded via your shell or python-dotenv.

# Nebius Token Factory (OpenAI-compatible)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
NEBIUS_EMBEDDING_BASE_URL=https://api.tokenfactory.nebius.com/v1

# Pinecone serverless
PINECONE_API_KEY=
PINECONE_INDEX=realestate-copilot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# LlamaParse
LLAMA_CLOUD_API_KEY=

# Week 3: Build-in-Public Content Agent
GITHUB_TOKEN=             # Personal access token with repo scope
GITHUB_PAGES_REPO=        # e.g. uttssss/agentic-ai-course-submissions
GITHUB_PAGES_POSTS_DIR=week3/githubpages  # folder inside the repo where posts are committed
